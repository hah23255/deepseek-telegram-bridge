# Master Tester Doctrine — gitignore

# Node
node_modules/
dist/
.cache/
.tsbuildinfo
*.tsbuildinfo

# Coverage / test artifacts
coverage/
.nyc_output/
.vitest-cache/
.stryker-tmp/
reports/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Env
.env
.env.local
.env.*.local

# Build artifacts of this skill (never commit packaged bundles)
*.skill
build/
